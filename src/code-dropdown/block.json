{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "wpe/code-dropdown",
	"version": "0.1.0",
	"title": "Code Dropdown",
	"category": "widgets",
	"icon": "screenoptions",
	"description": "An interactive block with the Interactivity API.",
	"example": {},
